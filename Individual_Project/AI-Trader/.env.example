# === API Keys (required) ===
# Get your own keys and fill in below:
#   - Anthropic / OpenAI-compatible: https://aihubmix.com or https://console.anthropic.com
#   - Alpha Vantage: https://www.alphavantage.co/support/#api-key
#   - Jina AI: https://jina.ai/
OPENAI_API_BASE=https://aihubmix.com/v1
OPENAI_API_KEY=your-api-key-here
ALPHAADVANTAGE_API_KEY=your-alpha-vantage-key-here
JINA_API_KEY=your-jina-api-key-here

# === MCP Service Ports ===
# Change these if you have port conflicts
MATH_HTTP_PORT=9000
SEARCH_HTTP_PORT=9001
TRADE_HTTP_PORT=9002
GETPRICE_HTTP_PORT=9003
CRYPTO_HTTP_PORT=9005

# === Agent Config ===
AGENT_MAX_STEP=30
RUNTIME_ENV_PATH=./runtime_env.json

# === Optional (for A-share market only) ===
TUSHARE_TOKEN=
